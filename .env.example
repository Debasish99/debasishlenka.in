# No env vars are required for the public site itself — photos are
# stored locally in public/photography and served via Next.js's
# built-in image optimization.

# --- Admin panel (/admin) ---
# A single shared password to log into the admin panel.
ADMIN_PASSWORD=

# Random string used to sign admin login sessions. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=

# GitHub Personal Access Token (fine-grained, scoped to this repo only,
# with "Contents: Read and write" permission). The admin panel uses this
# to commit new/edited/deleted posts directly to your repo, which then
# auto-deploys via Vercel's GitHub integration.
GITHUB_TOKEN=

# e.g. "yourusername/debasishlenka-in"
GITHUB_REPO=

# Defaults to "main" if not set
GITHUB_BRANCH=main
